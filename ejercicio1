#include <iostream>

using namespace std;
int main(){

int num1, num2, num3;

cout<< "Ingrese el primer numero: ";
cin>> num1;
cout<< "Ingrese el segundo numero: ";
cin>> num2;
cout<< "Ingrese el tercer numero: ";
cin>> num3;
int promedio = (num1 + num2 + num3) / 3;
cout<< "El promedio es: " << promedio << endl;



    return 0;
}

/*Este codigo es de complejidad constante, ya que el numero de operaciones no depende de la cantidad de numeros ingresados, 
siempre se realizan las mismas operaciones para calcular el promedio de tres numeros.*/
